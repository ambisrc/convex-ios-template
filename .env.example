# Convex
CONVEX_DEPLOYMENT=dev:your-convex-deployment
CONVEX_DEPLOYMENT_URL=https://your-convex-deployment.convex.cloud

# Apple Sign In
APPLE_SIGN_IN_CLIENT_IDS=com.ambimake.reflection
APPLE_SIGN_IN_CLIENT_SECRET=replace-with-generated-apple-client-secret

# Voice transcription
GROQ_API_KEY=replace-with-groq-api-key

# Error reporting
SENTRY_DSN=https://public-key@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=replace-with-sentry-auth-token
SENTRY_ORG_SLUG=example-org
SENTRY_PROJECT_SLUG=voice-agent

# Product analytics for iOS event capture
POSTHOG_API_KEY=replace-with-posthog-project-api-key
POSTHOG_HOST=https://app.posthog.com

# Product analytics account-cleanup request
POSTHOG_PROJECT_ID=00000
POSTHOG_PERSONAL_API_KEY=replace-with-posthog-personal-api-key
